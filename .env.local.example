# ============================================
# Supabase Configuration
# ============================================

# Public Supabase URL (from your Supabase project settings)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Public Supabase Anon Key (from your Supabase project settings)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-side Service Role Key (keep this SECRET - never commit to git)
# Only use this on the server, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# Optional: Other Configuration
# ============================================

# Database name (usually 'postgres')
# DATABASE_NAME=postgres

# API Base URL (if you deploy the API separately)
# VITE_API_URL=http://localhost:3000
